        "php": ">=8.5",
        "dompdf/dompdf": "^2.0",
        "phpoffice/phpword": "^1.2",
        "phpoffice/phpspreadsheet": "^2.0",
        "sabberworm/php-css-parser": "8.6.0"
    },
    "autoload": {
